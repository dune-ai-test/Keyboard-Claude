<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.CustomKeyboard" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/app_primary</item>
        <item name="colorPrimaryVariant">@color/app_primary_variant</item>
        <item name="android:colorBackground">@color/app_background</item>
        <item name="colorSurface">@color/app_surface</item>
        <item name="colorOnSurface">@color/app_on_surface</item>
        <item name="android:statusBarColor">@color/app_background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    </style>

    <style name="Theme.CustomKeyboard.Keyboard" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowBackground">@color/kb_background</item>
    </style>
</resources>
