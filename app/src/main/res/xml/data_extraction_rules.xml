<?xml version="1.0" encoding="utf-8"?>
<!-- Clipboard history and dictionaries are excluded from cloud backup/transfer for privacy. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="clipboard_history.db" />
        <exclude domain="database" path="clipboard_history.db-shm" />
        <exclude domain="database" path="clipboard_history.db-wal" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="clipboard_history.db" />
    </device-transfer>
</data-extraction-rules>
