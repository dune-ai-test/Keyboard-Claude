<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/keyboardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/kb_background">

    <!-- Single top row: toolbar icons by default, swapped for suggestion chips while there are
         predictions to show. They share the same space (never stacked), so no extra "section"
         ever opens up — the settings/clipboard/etc. row is always available in the same spot. -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:background="@color/kb_background">

        <LinearLayout
            android:id="@+id/toolbarRow"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <ImageButton
                android:id="@+id/btnSwitchKeyboard"
                style="@style/ToolbarIconButton"
                android:src="@drawable/ic_grid"
                android:contentDescription="Switch keyboard" />

            <ImageButton
                android:id="@+id/btnSettings"
                style="@style/ToolbarIconButton"
                android:src="@drawable/ic_settings"
                android:contentDescription="Keyboard settings" />

            <ImageButton
                android:id="@+id/btnEmoji"
                style="@style/ToolbarIconButton"
                android:src="@drawable/ic_emoji"
                android:contentDescription="Emoji" />

            <ImageButton
                android:id="@+id/btnUndo"
                style="@style/ToolbarIconButton"
                android:src="@drawable/ic_undo"
                android:contentDescription="Undo" />

            <ImageButton
                android:id="@+id/btnClipboard"
                style="@style/ToolbarIconButton"
                android:src="@drawable/ic_clipboard"
                android:contentDescription="@string/clipboard_manager" />

            <ImageButton
                android:id="@+id/btnCursorMove"
                style="@style/ToolbarIconButton"
                android:src="@drawable/ic_cursor_move"
                android:contentDescription="Move cursor" />

            <ImageButton
                android:id="@+id/btnVoice"
                style="@style/ToolbarIconButton"
                android:src="@drawable/ic_mic"
                android:contentDescription="Voice typing" />
        </LinearLayout>

        <!-- Suggestion / prediction strip. Occupies the exact same row as the toolbar above —
             only one of the two is visible at a time, so showing suggestions never adds height
             or hides the toolbar permanently; it's simply swapped back once typing stops. -->
        <LinearLayout
            android:id="@+id/suggestionBar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/kb_background"
            android:visibility="gone">

            <TextView
                android:id="@+id/suggestion1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:textSize="15sp"
                android:textColor="@color/kb_key_text"
                android:background="@drawable/bg_suggestion_ripple"
                android:singleLine="true"
                android:ellipsize="end"
                tools:text="word" />

            <View android:layout_width="1dp" android:layout_height="20dp" android:background="@color/kb_divider" />

            <TextView
                android:id="@+id/suggestion2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:textSize="15sp"
                android:textColor="@color/kb_key_text"
                android:background="@drawable/bg_suggestion_ripple"
                android:singleLine="true"
                android:ellipsize="end"
                tools:text="prediction" />

            <View android:layout_width="1dp" android:layout_height="20dp" android:background="@color/kb_divider" />

            <TextView
                android:id="@+id/suggestion3"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:textSize="15sp"
                android:textColor="@color/kb_key_text"
                android:background="@drawable/bg_suggestion_ripple"
                android:singleLine="true"
                android:ellipsize="end"
                tools:text="engine" />
        </LinearLayout>
    </FrameLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/kb_divider" />

    <!-- Main content area: either the keyboard rows or the full clipboard panel -->
    <FrameLayout
        android:id="@+id/contentArea"
        android:layout_width="match_parent"
        android:layout_height="220dp">

        <com.example.customkeyboard.ui.KeyboardView
            android:id="@+id/keyboardView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <include
            android:id="@+id/clipboardPanel"
            layout="@layout/panel_clipboard"
            android:visibility="gone" />
    </FrameLayout>

</LinearLayout>
