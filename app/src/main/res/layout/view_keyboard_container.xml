<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/keyboardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/kb_background">

    <!-- Suggestion / prediction / clipboard strip -->
    <LinearLayout
        android:id="@+id/suggestionBar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/suggestion_bar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/kb_background">

        <TextView
            android:id="@+id/suggestion1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="15sp"
            android:textColor="@color/kb_key_text"
            android:background="@drawable/bg_suggestion_ripple"
            android:singleLine="true"
            android:ellipsize="end"
            tools:text="word" />

        <View android:layout_width="1dp" android:layout_height="20dp" android:background="@color/kb_divider" />

        <TextView
            android:id="@+id/suggestion2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="15sp"
            android:textColor="@color/kb_key_text"
            android:background="@drawable/bg_suggestion_ripple"
            android:singleLine="true"
            android:ellipsize="end"
            tools:text="prediction" />

        <View android:layout_width="1dp" android:layout_height="20dp" android:background="@color/kb_divider" />

        <TextView
            android:id="@+id/suggestion3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="15sp"
            android:textColor="@color/kb_key_text"
            android:background="@drawable/bg_suggestion_ripple"
            android:singleLine="true"
            android:ellipsize="end"
            tools:text="engine" />

        <ImageButton
            android:id="@+id/clipboardButton"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_suggestion_ripple"
            android:src="@drawable/ic_clipboard"
            android:contentDescription="@string/clipboard_manager"
            android:tint="@color/kb_key_subtext" />
    </LinearLayout>

    <!-- Optional inline clipboard history row, toggled visible by the IME -->
    <HorizontalScrollView
        android:id="@+id/clipboardStripScroll"
        android:layout_width="match_parent"
        android:layout_height="@dimen/suggestion_bar_height"
        android:visibility="gone"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/clipboardStrip"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:gravity="center_vertical" />
    </HorizontalScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/kb_divider" />

    <com.example.customkeyboard.ui.KeyboardView
        android:id="@+id/keyboardView"
        android:layout_width="match_parent"
        android:layout_height="220dp" />

</LinearLayout>
