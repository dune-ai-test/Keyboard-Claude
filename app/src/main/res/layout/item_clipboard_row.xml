<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_clipboard_row"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    android:layout_marginTop="3dp"
    android:layout_marginBottom="3dp"
    android:padding="8dp">

    <ImageView
        android:id="@+id/dragHandle"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_drag_handle"
        android:tint="@color/kb_key_subtext"
        android:contentDescription="Reorder" />

    <TextView
        android:id="@+id/clipText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="4dp"
        android:maxLines="4"
        android:ellipsize="end"
        android:textColor="@color/kb_key_text"
        android:textSize="14sp"
        tools:text="This is a full clipboard entry shown in full, not truncated to one line." />

    <ImageButton
        android:id="@+id/pinButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_suggestion_ripple"
        android:src="@drawable/ic_pin"
        android:padding="7dp"
        android:scaleType="centerInside"
        android:tint="@color/kb_key_subtext"
        android:contentDescription="Pin" />

    <ImageButton
        android:id="@+id/deleteButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_suggestion_ripple"
        android:src="@drawable/ic_delete"
        android:padding="7dp"
        android:scaleType="centerInside"
        android:tint="@color/kb_key_subtext"
        android:contentDescription="Delete" />

</LinearLayout>
