<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/kb_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="12dp">

        <ImageButton
            android:id="@+id/clipboardBackButton"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_suggestion_ripple"
            android:src="@drawable/ic_back"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:tint="@color/kb_toolbar_icon"
            android:contentDescription="Close clipboard" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/clipboard_manager"
            android:textColor="@color/kb_key_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/clipboardClearButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clear"
            android:textColor="@color/kb_accent"
            android:textSize="14sp"
            android:padding="6dp"
            android:background="@drawable/bg_suggestion_ripple" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/kb_divider" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/clipboardRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/clipboardEmptyText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="No clipboard history yet"
            android:textColor="@color/kb_key_subtext"
            android:textSize="14sp"
            android:visibility="gone" />
    </FrameLayout>

</LinearLayout>
